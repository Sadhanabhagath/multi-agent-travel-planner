# ============================================================
# Multi-Agent Travel Planner — Environment Configuration
# Copy this file to .env and fill in your values
# ============================================================

# ---- LLM Provider (choose one or both) ----
OPENAI_API_KEY=sk-your-openai-key-here
ANTHROPIC_API_KEY=sk-ant-your-anthropic-key-here

# Default model to use
DEFAULT_LLM_MODEL=gpt-4o-mini          # or claude-3-5-haiku-20241022
ORCHESTRATOR_LLM_MODEL=gpt-4o          # Powerful model for orchestration

# ---- Travel API Keys ----
# Amadeus (Flights): https://developers.amadeus.com
AMADEUS_CLIENT_ID=your-amadeus-client-id
AMADEUS_CLIENT_SECRET=your-amadeus-client-secret
AMADEUS_ENVIRONMENT=test               # test | production

# Google Places (Activities): https://console.cloud.google.com
GOOGLE_PLACES_API_KEY=your-google-places-key

# Exchange Rates: https://exchangeratesapi.io
EXCHANGE_RATES_API_KEY=your-exchange-rates-key

# ---- Agent Behavior ----
MAX_FLIGHT_RESULTS=5
MAX_HOTEL_RESULTS=5
MAX_ACTIVITY_RESULTS=10
BUDGET_BUFFER_PERCENT=10              # Keep 10% buffer from stated budget
MAX_AGENT_ITERATIONS=10              # Safety cap for agent loops
ENABLE_HUMAN_IN_LOOP=true            # Pause for user approval checkpoints

# ---- Caching ----
ENABLE_CACHE=true
CACHE_TTL_SECONDS=3600               # 1 hour cache for API responses
REDIS_URL=redis://localhost:6379/0   # Leave blank to use disk cache

# ---- Observability ----
LANGSMITH_API_KEY=your-langsmith-key
LANGSMITH_PROJECT=travel-planner
ENABLE_TRACING=false

# ---- App Settings ----
LOG_LEVEL=INFO
APP_ENV=development                  # development | production
